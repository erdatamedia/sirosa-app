generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FARMER
}

model User {
  id         String    @id @default(cuid())
  email      String?   @unique
  password   String?
  name       String
  role       Role      @default(FARMER)
  phone      String?
  address    String?
  farmerId   String?   @unique
  farm            Farm?              @relation("FarmOwner")
  predictions     PredictionHistory[]
  milkProductions MilkProduction[]
  createdAt       DateTime           @default(now())

  @@map("users")
}

model Farm {
  id        String   @id @default(cuid())
  name      String
  address   String?
  owner     User     @relation("FarmOwner", fields: [ownerId], references: [id])
  ownerId   String   @unique
  cows      Cow[]
  createdAt DateTime @default(now())

  @@map("farms")
}

enum CowStatus {
  ACTIVE
  DRY
  CULLED
}

model Cow {
  id               String            @id @default(cuid())
  earTag           String            @unique
  name             String?
  birthDate        DateTime?
  parity           Int               @default(1)
  currentWeight    Float?
  currentBCS       Float?
  lactationMonth   Int?
  status           CowStatus         @default(ACTIVE)
  farm             Farm              @relation(fields: [farmId], references: [id])
  farmId           String
  milkProductions  MilkProduction[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("cows")
}

enum MilkSession {
  MORNING
  AFTERNOON
}

model MilkProduction {
  id         String      @id @default(cuid())
  cow        Cow         @relation(fields: [cowId], references: [id])
  cowId      String
  date       DateTime
  session    MilkSession @default(MORNING)
  amount     Float
  recordedBy User        @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime    @default(now())

  @@map("milk_productions")
}

model PredictionHistory {
  id        Int      @id @default(autoincrement())
  model     String
  parity    Int?
  ll        Int
  bcs       Float
  weight    Float?
  result    Float
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("prediction_histories")
}
